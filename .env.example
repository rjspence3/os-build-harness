# buildHarness env — populate locally; never commit the real .env.
# Only needed for LIVE runs (MCP authoring + authenticated CDP capture). The
# dry-run path (build_banking.py --dry-run) and the test suite need none of these.

# OutSystems Mentor MCP tenant (used by harness/banking_runner/mcp_client.py)
OUTSYSTEMS_MCP_TENANT=your-tenant.outsystems.dev

# Home Banking portal demo credentials (used by cdp_* capture scripts)
HB_PORTAL_USER=
HB_PORTAL_PASS=
