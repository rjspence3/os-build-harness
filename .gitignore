.env
.DS_Store
__pycache__/
*.pyc
.venv/
*.db
*.log
.pytest_cache/
*.egg-info/
build/

# Throwaway diagnostic outputs (regenerable)
*.png
# ...but _raw/resources/ PNGs are real UI assets to re-host in the clone (keep tracked)
!builds/*/MCP_RECIPES/apps/*/_raw/resources/*.png
builds/*/banking_runner_out/
builds/*/runner_state.db

# Figma PAT (never commit)
.figma_token
*.figma_token

# build artifacts
_prompts/
_prompts*/
builds/gate_demo/
.playwright-mcp/

# Build-runner state DBs (SQLite despite the .json name) — regenerable per run, never commit
*.state.json
_state_final/
# Throwaway experimental spec variants (superseded by the canonical <App>.app_spec.json)
*_r.app_spec.json
*_notopbar.app_spec.json

# Local diagnostic/scratch — internal, never publish (may reference the real tenant)
TENANT_AGENT_AUDIT.md
DELETE_MANIFEST.md
SESSION_HANDOFF.md
*_console.theme.css

# .claude scratch — keep settings.json + hooks/ public; never publish personal/scratch
.claude/settings.local.json
.claude/plans/
