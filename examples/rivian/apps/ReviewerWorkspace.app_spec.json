          {
            "label": "Functional Review",
            "state": "active"
          },
          {
            "label": "Approval",
            "state": "pending"
          },
          {
            "label": "Activation",
            "state": "pending"
          }
        ],
        "reviewTeams": [
          "Procurement",
          "Quality",
          "Engineering",
          "Compliance"
        ],
        "reviewEntity": "ReviewTask",
        "reviewStateField": "State",
        "timelineEntity": "AuditEvent",
        "timelineFields": [
          "Description",
          "Actor",
          "At"
        ]
      },
      "components": [
        {
          "id": "caseBody",
          "type": "Container"
        }
      ],
      "acceptance": {
        "assertions": [
          {
            "kind": "componentPresent",
