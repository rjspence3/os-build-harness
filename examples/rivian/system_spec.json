{
  "specVersion": "0.1",
  "system": {
    "name": "rivian_supplier_onboarding",
    "apps": [
      {
        "name": "RivianDesignSystem",
        "kind": "Library",
        "layer": "foundation",
        "exposes": {}
      },
      {
        "name": "OnboardingCore",
        "kind": "WebApplication",
        "layer": "core",
        "context": "onboarding",
        "owns": [
          "Supplier",
          "Contact",
          "Part",
          "QualificationCase",
          "ReviewTask",
          "Document",
          "ScreeningResult",
          "AuditEvent"
        ],
        "exposes": {
          "serviceActions": [
            "SubmitOnboarding",
            "UploadDocument",
            "SubmitReview",
            "ApproveCase",
            "ReleasePart",
            "CaptureFeedback"
          ],
          "events": [
            "OnboardingSubmitted",
            "CaseApproved"
          ],
          "staticEntities": []
        },
        "foreignKeys": [
          {
            "from": "Contact",
            "target": "Supplier"
          },
          {
            "from": "Part",
            "target": "Supplier"
          },
          {
            "from": "QualificationCase",
            "target": "Supplier"
          },
          {
            "from": "QualificationCase",
            "target": "Part"
          },
          {
            "from": "ReviewTask",
            "target": "QualificationCase"
          },
          {
            "from": "Document",
            "target": "Supplier"
          },
          {
            "from": "Document",
            "target": "QualificationCase"
          },
          {
            "from": "ScreeningResult",
            "target": "Supplier"
          },
          {
            "from": "AuditEvent",
            "target": "QualificationCase"
          }
        ],
        "consumes": []
      },
      {
        "name": "DeniedPartyScreenAgent",
        "kind": "AIAgent",
        "layer": "orchestration",
        "exposes": {
          "serviceActions": [
            "DeniedPartyScreen"
          ]
        },
        "consumes": [
          {
            "app": "OnboardingCore",
            "entities": [
              "Supplier"
            ]
          }
        ]
      },
      {
        "name": "QualifyWorkflow",
        "kind": "BusinessProcess",
        "layer": "orchestration",
        "process": {
          "triggerEvent": "OnboardingSubmitted",
          "startProcessOn": "OnboardingCore.OnboardingSubmitted"
        },
        "activities": [
          {
            "name": "Screen",
            "callsServiceAction": "DeniedPartyScreen"
          },
          {
            "name": "ParallelReviews",
            "callsServiceAction": "SubmitReview"
          },
          {
            "name": "Approve",
            "callsServiceAction": "ApproveCase"
          },
          {
            "name": "Activate",
            "callsServiceAction": "ReleasePart"
          }
        ],
        "consumes": [
          {
            "app": "OnboardingCore",
            "events": [
              "OnboardingSubmitted"
            ],
            "serviceActions": [
              "ApproveCase",
              "ReleasePart",
              "SubmitReview"
            ]
          },
          {
            "app": "DeniedPartyScreenAgent",
            "serviceActions": [
              "DeniedPartyScreen"
            ]
          }
        ]
      },
      {
        "name": "ReviewerApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "reviewer",
        "exposes": {
          "screens": [
            "ReviewQueue",
            "EvaluateCase",
            "ApproveCase",
            "ReleasePart",
            "CaptureFeedback"
          ]
        },
        "consumes": [
          {
            "app": "OnboardingCore",
            "entities": [
              "AuditEvent",
              "Document",
              "Part",
              "QualificationCase",
              "ReviewTask"
            ],
            "serviceActions": [
              "ApproveCase",
              "CaptureFeedback",
              "ReleasePart",
              "SubmitReview"
            ]
          },
          {
            "app": "RivianDesignSystem"
          }
        ]
      },
      {
        "name": "SupplierApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "supplier",
        "exposes": {
          "screens": [
            "SubmitIntake",
            "UploadDocument",
            "TrackStatus"
          ]
        },
        "consumes": [
          {
            "app": "OnboardingCore",
            "entities": [
              "Contact",
              "Document",
              "Part",
              "QualificationCase",
              "ScreeningResult",
              "Supplier"
            ],
            "serviceActions": [
              "SubmitOnboarding",
              "UploadDocument"
            ]
          },
          {
            "app": "RivianDesignSystem"
          }
        ]
      }
    ]
  }
}