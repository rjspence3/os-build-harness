{
  "specVersion": "0.1",
  "domain": {
    "name": "rivian_supplier_onboarding",
    "description": "Rivian Supplier & Parts Onboarding — governed ODC application replacing the Appian/PowerPlatform workflow. Supplier self-service intake + internal reviewer case-management + tiered qualification workflow with parallel functional reviews, denied-party screening, multi-step approval, immutable audit. FR-01..21.",
    "entities": [
      {"name": "Supplier", "context": "onboarding", "naturalKey": "Code",
       "attributes": [{"name": "Code", "dataType": "Text", "mandatory": true},
                      {"name": "Name", "dataType": "Text", "mandatory": true},
                      {"name": "Tier", "dataType": "Text"},
                      {"name": "Status", "dataType": "Text"},
                      {"name": "Country", "dataType": "Text"},
                      {"name": "TaxId", "dataType": "Text"}]},
      {"name": "Contact", "context": "onboarding", "references": ["Supplier"], "naturalKey": "Email",
       "attributes": [{"name": "Name", "dataType": "Text", "mandatory": true},
                      {"name": "Email", "dataType": "Email", "mandatory": true},
                      {"name": "Phone", "dataType": "PhoneNumber"},
                      {"name": "Role", "dataType": "Text"}]},
      {"name": "Part", "context": "onboarding", "references": ["Supplier"], "naturalKey": "Sku",
       "attributes": [{"name": "Sku", "dataType": "Text", "mandatory": true},
                      {"name": "Name", "dataType": "Text", "mandatory": true},
                      {"name": "Category", "dataType": "Text"},
                      {"name": "Status", "dataType": "Text"}]},
      {"name": "QualificationCase", "context": "onboarding", "references": ["Supplier", "Part"], "naturalKey": "CaseNo",
       "attributes": [{"name": "CaseNo", "dataType": "Text", "mandatory": true},
                      {"name": "Tier", "dataType": "Text"},
                      {"name": "Status", "dataType": "Text"},
                      {"name": "Stage", "dataType": "Text"},
                      {"name": "Score", "dataType": "Text"},
                      {"name": "SlaState", "dataType": "Text"},
                      {"name": "Owner", "dataType": "Text"}]},
      {"name": "ReviewTask", "context": "onboarding", "references": ["QualificationCase"],
       "attributes": [{"name": "Team", "dataType": "Text", "mandatory": true},
                      {"name": "State", "dataType": "Text"},
                      {"name": "DueDate", "dataType": "Text"}]},
      {"name": "Document", "context": "onboarding", "references": ["Supplier", "QualificationCase"],
       "attributes": [{"name": "Name", "dataType": "Text", "mandatory": true},
                      {"name": "Type", "dataType": "Text"},
                      {"name": "Url", "dataType": "Text"},
                      {"name": "UploadedAt", "dataType": "Text"}]},
      {"name": "ScreeningResult", "context": "onboarding", "references": ["Supplier"],
       "attributes": [{"name": "Provider", "dataType": "Text"},
                      {"name": "Match", "dataType": "Text"},
                      {"name": "Status", "dataType": "Text"},
                      {"name": "CheckedAt", "dataType": "Text"}]},
      {"name": "AuditEvent", "context": "onboarding", "references": ["QualificationCase"],
       "attributes": [{"name": "Description", "dataType": "Text", "mandatory": true},
                      {"name": "Actor", "dataType": "Text"},
                      {"name": "At", "dataType": "Text"}]}
    ],
    "actors": ["supplier", "reviewer"],
    "capabilities": [
      {"name": "SubmitIntake", "actor": "supplier", "reads": ["Supplier", "Part"],
       "writes": ["Supplier", "Contact", "Part", "QualificationCase"],
       "service": "SubmitOnboarding", "raisesEvent": "OnboardingSubmitted"},
      {"name": "UploadDocument", "actor": "supplier", "writes": ["Document"], "service": "UploadDocument"},
      {"name": "TrackStatus", "actor": "supplier", "reads": ["QualificationCase", "Document", "ScreeningResult"]},

      {"name": "ReviewQueue", "actor": "reviewer", "reads": ["QualificationCase", "ReviewTask"]},
      {"name": "EvaluateCase", "actor": "reviewer", "reads": ["QualificationCase", "ReviewTask", "Document", "AuditEvent"],
       "writes": ["ReviewTask", "AuditEvent"], "service": "SubmitReview"},
      {"name": "ApproveCase", "actor": "reviewer", "reads": ["QualificationCase"],
       "writes": ["QualificationCase", "AuditEvent"], "service": "ApproveCase", "raisesEvent": "CaseApproved"},
      {"name": "ReleasePart", "actor": "reviewer", "reads": ["Part", "QualificationCase"],
       "writes": ["Part"], "service": "ReleasePart"},
      {"name": "CaptureFeedback", "actor": "reviewer", "writes": ["AuditEvent"], "service": "CaptureFeedback"},

      {"name": "Qualify", "orchestrates": true, "triggerEvent": "OnboardingSubmitted",
       "steps": [
         {"name": "Screen", "ai": "DeniedPartyScreen", "reads": ["Supplier"], "writes": ["ScreeningResult"]},
         {"name": "AssignTier", "reads": ["QualificationCase", "Part"], "writes": ["QualificationCase"]},
         {"name": "ParallelReviews", "callsService": "SubmitReview"},
         {"name": "Approve", "callsService": "ApproveCase"},
         {"name": "Activate", "callsService": "ReleasePart"}
       ]}
    ],
    "integrations": [
      {"name": "PLM", "kind": "consume", "purpose": "part & change data", "stub": true},
      {"name": "ERP", "kind": "consume", "purpose": "vendor master write on activation", "stub": true},
      {"name": "SSO", "kind": "identity", "purpose": "SSO/MFA sign-in + roles", "stub": true},
      {"name": "DeniedParty", "kind": "consume", "purpose": "sanctions/denied-party screening", "stub": true},
      {"name": "DocStorage", "kind": "consume", "purpose": "document upload/store", "stub": true}
    ],
    "libraries": ["RivianDesignSystem"],
    "design": {
      "source": "referenceApp",
      "referenceName": "Rivian Supplier Onboarding",
      "themeReference": "design/rivian-design-system/tokens/tokens.css",
      "mode": "dark"
    }
  }
}
