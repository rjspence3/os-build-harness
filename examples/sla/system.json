{
  "specVersion": "0.1",
  "system": {
    "name": "new_business_sla",
    "apps": [
      {
        "name": "SlaCore",
        "kind": "WebApplication",
        "layer": "core",
        "context": "sla",
        "owns": [
          "CaseOwner",
          "Application",
          "Requirement"
        ],
        "exposes": {
          "serviceActions": [],
          "events": [],
          "staticEntities": []
        },
        "foreignKeys": [
          {
            "from": "Application",
            "target": "CaseOwner"
          },
          {
            "from": "Requirement",
            "target": "Application"
          }
        ],
        "consumes": []
      },
      {
        "name": "SLAOpsAgentAgent",
        "kind": "AIAgent",
        "layer": "orchestration",
        "exposes": {
          "serviceActions": [
            "SLAOpsAgent"
          ]
        },
        "consumes": [
          {
            "app": "SlaCore",
            "entities": [
              "CaseOwner",
              "Requirement",
              "Application"
            ]
          }
        ]
      },
      {
        "name": "CaseManagerApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "case-manager",
        "exposes": {
          "screens": [
            "ViewPipeline",
            "ApplicationDetail",
            "SLAAssistant"
          ]
        },
        "consumes": [
          {
            "app": "SlaCore",
            "entities": [
              "Application",
              "CaseOwner",
              "Requirement"
            ]
          },
          {
            "app": "SLAOpsAgentAgent",
            "serviceActions": [
              "SLAOpsAgent"
            ]
          }
        ]
      },
      {
        "name": "OperationsLeadApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "operations-lead",
        "exposes": {
          "screens": [
            "MonitorSLA"
          ]
        },
        "consumes": [
          {
            "app": "SlaCore",
            "entities": [
              "Application",
              "CaseOwner",
              "Requirement"
            ]
          }
        ]
      }
    ]
  }
}