{
  "specVersion": "0.2",
  "app": {"name": "SLATracker", "roles": ["CaseManager", "OperationsLead"],
          "description": "New Business SLA Tracker — pipeline, SLA deadlines, outstanding requirements; hosts the SLA Ops Agent."},
  "dataModel": {"entities": [
    {"name": "CaseOwner", "attributes": [
      {"name": "Id", "dataType": "Identifier", "isIdentifier": true, "mandatory": true},
      {"name": "Name", "dataType": "Text", "length": 100, "mandatory": true},
      {"name": "Email", "dataType": "Email", "mandatory": true},
      {"name": "Team", "dataType": "Text", "length": 30, "mandatory": true}]},
    {"name": "Application", "attributes": [
      {"name": "Id", "dataType": "Identifier", "isIdentifier": true, "mandatory": true},
      {"name": "ApplicantName", "dataType": "Text", "length": 100, "mandatory": true},
      {"name": "Product", "dataType": "Text", "length": 30, "mandatory": true},
      {"name": "FaceAmount", "dataType": "Decimal", "mandatory": true},
      {"name": "SubmittedOn", "dataType": "Date", "mandatory": true},
      {"name": "CurrentStage", "dataType": "Text", "length": 30, "mandatory": true},
      {"name": "Status", "dataType": "Text", "length": 20, "mandatory": true},
      {"name": "SLADueOn", "dataType": "Date", "mandatory": true},
      {"name": "LastActivityOn", "dataType": "Date", "mandatory": true},
      {"name": "CaseOwnerId", "dataType": "Identifier", "references": "CaseOwner", "mandatory": true}]},
    {"name": "Requirement", "attributes": [
      {"name": "Id", "dataType": "Identifier", "isIdentifier": true, "mandatory": true},
      {"name": "RequirementType", "dataType": "Text", "length": 30, "mandatory": true},
      {"name": "Status", "dataType": "Text", "length": 20, "mandatory": true},
      {"name": "RequestedOn", "dataType": "Date", "mandatory": true},
      {"name": "ReceivedOn", "dataType": "Date"},
      {"name": "ApplicationId", "dataType": "Identifier", "references": "Application", "mandatory": true}],
      "sampleData": [
        {"RequirementType": "Suitability Review", "Status": "Outstanding", "RequestedOn": "2026-06-26"},
        {"RequirementType": "Paramedical Exam", "Status": "Outstanding", "RequestedOn": "2026-06-28"}]}
  ]},
  "screens": [
    {"id": "pipeline", "name": "PipelineList", "isDefault": true, "roles": ["CaseManager", "OperationsLead"],
     "components": [{"id": "appsTable", "type": "Table", "boundTo": "Application"}],
     "acceptance": {"assertions": [
       {"kind": "entityExists", "entity": "Application"},
       {"kind": "componentPresent", "componentId": "appsTable"},
       {"kind": "binding", "componentId": "appsTable", "boundTo": "Application"}]}},
    {"id": "appdetail", "name": "ApplicationDetail", "roles": ["CaseManager", "OperationsLead"],
     "inputParameters": [{"name": "ApplicationId", "dataType": "Identifier", "references": "Application"}],
     "components": [{"id": "reqTable", "type": "Table", "boundTo": "Requirement"}],
     "acceptance": {"assertions": [{"kind": "componentPresent", "componentId": "reqTable"}]}},
    {"id": "assistant", "name": "SLAAssistant", "roles": ["CaseManager"],
     "components": [{"id": "assistantPanel", "type": "Container", "label": "SLA Assistant"}],
     "acceptance": {"assertions": [{"kind": "componentPresent", "componentId": "assistantPanel"}]}}
  ],
  "agents": [
    {"name": "SLAOpsAgent", "modelConnection": "TrialClaudeHaiku4_5",
     "systemPrompt": "You are the New Business SLA Ops Agent for a life insurer. Help case managers keep applications within SLA. Use the SLA Tracker data for pipeline state, SLA dates, and outstanding requirements. When asked about delays, list applications past their stage SLA and, for each, the exact outstanding requirement. Draft concise professional follow-ups to the case owner. Cite the Application ID for every claim. Never invent policy details or numbers; if data is missing, say so. Never send a message — produce drafts for human approval only.",
     "tools": ["QueryPipeline", "GetOutstandingRequirements", "DraftOutreach"]}
  ]
}
