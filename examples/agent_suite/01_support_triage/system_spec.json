{
  "specVersion": "0.1",
  "system": {
    "name": "support_triage",
    "apps": [
      {
        "name": "SupportDesignSystem",
        "kind": "Library",
        "layer": "foundation",
        "exposes": {}
      },
      {
        "name": "SupportCore",
        "kind": "WebApplication",
        "layer": "core",
        "context": "support",
        "owns": [
          "Customer",
          "PolicyDoc",
          "Ticket",
          "ResolutionAction",
          "AuditEvent"
        ],
        "exposes": {
          "serviceActions": [
            "SubmitTicket",
            "TriageTicket",
            "ResolveTicket",
            "EscalateTicket",
            "ApproveResolution",
            "SavePolicy"
          ],
          "events": [
            "TicketSubmitted"
          ],
          "staticEntities": []
        },
        "foreignKeys": [
          {
            "from": "Ticket",
            "target": "Customer"
          },
          {
            "from": "ResolutionAction",
            "target": "Ticket"
          },
          {
            "from": "AuditEvent",
            "target": "Ticket"
          }
        ],
        "consumes": []
      },
      {
        "name": "ResolutionWorkflow",
        "kind": "BusinessProcess",
        "layer": "orchestration",
        "process": {
          "triggerEvent": "TicketSubmitted",
          "startProcessOn": "SupportCore.TicketSubmitted"
        },
        "activities": [
          {
            "name": "Triage",
            "callsServiceAction": "TriageAgent"
          },
          {
            "name": "Approve",
            "callsServiceAction": "ResolveTicket"
          }
        ],
        "consumes": [
          {
            "app": "SupportCore",
            "events": [
              "TicketSubmitted"
            ],
            "serviceActions": [
              "ResolveTicket"
            ]
          },
          {
            "app": "TriageAgent",
            "serviceActions": [
              "TriageAgent"
            ]
          }
        ]
      },
      {
        "name": "TriageAgent",
        "kind": "AIAgent",
        "layer": "orchestration",
        "exposes": {
          "serviceActions": [
            "TriageAgent"
          ]
        },
        "consumes": [
          {
            "app": "SupportCore",
            "entities": [
              "Ticket",
              "PolicyDoc"
            ]
          }
        ]
      },
      {
        "name": "AdminApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "admin",
        "exposes": {
          "screens": [
            "ManagePolicies",
            "AuditTrail"
          ]
        },
        "consumes": [
          {
            "app": "SupportCore",
            "entities": [
              "AuditEvent",
              "PolicyDoc",
              "Ticket"
            ],
            "serviceActions": [
              "SavePolicy"
            ]
          },
          {
            "app": "SupportDesignSystem"
          }
        ]
      },
      {
        "name": "CustomerApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "customer",
        "exposes": {
          "screens": [
            "SubmitTicket"
          ]
        },
        "consumes": [
          {
            "app": "SupportCore",
            "entities": [
              "AuditEvent",
              "Customer",
              "Ticket"
            ],
            "serviceActions": [
              "SubmitTicket"
            ]
          },
          {
            "app": "SupportDesignSystem"
          }
        ]
      },
      {
        "name": "SupportAgentApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "support_agent",
        "exposes": {
          "screens": [
            "ResolveTicket",
            "EscalateTicket",
            "MyQueue",
            "ApprovalInbox"
          ]
        },
        "consumes": [
          {
            "app": "SupportCore",
            "entities": [
              "AuditEvent",
              "Customer",
              "ResolutionAction",
              "Ticket"
            ],
            "serviceActions": [
              "ApproveResolution",
              "EscalateTicket",
              "ResolveTicket"
            ]
          },
          {
            "app": "SupportDesignSystem"
          }
        ]
      }
    ]
  }
}