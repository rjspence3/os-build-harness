{
  "specVersion": "0.1",
  "domain": {
    "name": "compliance_audit",
    "description": "Compliance & audit prep (use case #7). A ComplianceAgent gathers control evidence, detects gaps against a framework (SOC2/ISO), and drafts remediation. The bounded action space it PROPOSES is attach-evidence | flag-gap | draft-remediation \u2014 it writes Evidence, GapFinding, and RemediationTask, but it NEVER attests. Evidence gathering auto-attaches; control attestations require a human control-owner to approve at an OutSystems approval workflow (BPT) before the control is marked satisfied. Every action is audited. The bounded action space + the human-at-the-attestation-write-step is what makes it ship, not just reason.",
    "entities": [
      {
        "name": "Framework",
        "context": "compliance",
        "naturalKey": "Code",
        "attributes": [
          {
            "name": "Code",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Name",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Version",
            "dataType": "Text"
          },
          {
            "name": "Description",
            "dataType": "Text",
            "length": 2000
          }
        ]
      },
      {
        "name": "Control",
        "context": "compliance",
        "naturalKey": "ControlNo",
        "references": [
          "Framework",
          "AuditEvent"
        ],
        "attributes": [
          {
            "name": "ControlNo",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Title",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Requirement",
            "dataType": "Text"
          },
          {
            "name": "Category",
            "dataType": "Text"
          },
          {
            "name": "Status",
            "dataType": "Text"
          },
          {
            "name": "SatisfiedOn",
            "dataType": "DateTime"
          },
          {
            "name": "ReadinessScore",
            "dataType": "Integer"
          }
        ]
      },
      {
        "name": "Evidence",
        "context": "compliance",
        "naturalKey": "EvidenceNo",
        "references": [
          "Control"
        ],
        "attributes": [
          {
            "name": "EvidenceNo",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Title",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "SourceSystem",
            "dataType": "Text"
          },
          {
            "name": "ArtifactUri",
            "dataType": "Text"
          },
          {
            "name": "CollectedAt",
            "dataType": "DateTime"
          },
          {
            "name": "AutoAttached",
            "dataType": "Boolean"
          }
        ]
      },
      {
        "name": "GapFinding",
        "context": "compliance",
        "references": [
          "Control"
        ],
        "attributes": [
          {
            "name": "Summary",
            "dataType": "Text",
            "mandatory": true,
            "length": 2000
          },
          {
            "name": "Severity",
            "dataType": "Text"
          },
          {
            "name": "Rationale",
            "dataType": "Text",
            "length": 2000
          },
          {
            "name": "Status",
            "dataType": "Text"
          },
          {
            "name": "Confidence",
            "dataType": "Integer"
          }
        ]
      },
      {
        "name": "RemediationTask",
        "context": "compliance",
        "references": [
          "Control",
          "GapFinding"
        ],
        "attributes": [
          {
            "name": "Title",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "DraftBody",
            "dataType": "Text",
            "length": 2000
          },
          {
            "name": "Owner",
            "dataType": "Text"
          },
          {
            "name": "DueDate",
            "dataType": "DateTime"
          },
          {
            "name": "Status",
            "dataType": "Text"
          }
        ]
      },
      {
        "name": "Attestation",
        "context": "compliance",
        "references": [
          "Control"
        ],
        "attributes": [
          {
            "name": "Decision",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Statement",
            "dataType": "Text"
          },
          {
            "name": "AttestedBy",
            "dataType": "Text"
          },
          {
            "name": "AttestedAt",
            "dataType": "DateTime"
          }
        ]
      },
      {
        "name": "AuditEvent",
        "context": "compliance",
        "attributes": [
          {
            "name": "Description",
            "dataType": "Text",
            "mandatory": true,
            "length": 2000
          },
          {
            "name": "Actor",
            "dataType": "Text"
          },
          {
            "name": "At",
            "dataType": "DateTime"
          }
        ]
      }
    ],
    "actors": [
      "compliance_analyst",
      "control_owner",
      "admin"
    ],
    "capabilities": [
      {
        "name": "StartControlReview",
        "actor": "compliance_analyst",
        "reads": [
          "Control",
          "Framework"
        ],
        "writes": [
          "Control",
          "AuditEvent"
        ],
        "service": "StartControlReview",
        "raisesEvent": "ControlReviewStarted",
        "note": "The analyst kicks off review of a control \u2014 sets it in-review and raises the event that starts the workflow."
      },
      {
        "name": "AssessControl",
        "ai": "ComplianceAgent",
        "reads": [
          "Control",
          "Evidence",
          "Framework"
        ],
        "writes": [
          "Evidence",
          "GapFinding",
          "RemediationTask",
          "AuditEvent"
        ],
        "service": "AssessControl",
        "note": "THE AGENT. Grounds on the Control + its Framework requirement + already-attached Evidence (native retrieval tool), then PROPOSES within a bounded action space: attach-evidence (auto-attaches gathered Evidence), flag-gap (a GapFinding with severity/confidence), draft-remediation (a RemediationTask draft). It writes Evidence/GapFinding/RemediationTask \u2014 it NEVER attests or marks the Control satisfied; that is the human write-step."
      },
      {
        "name": "AttachEvidence",
        "actor": "compliance_analyst",
        "reads": [
          "Control",
          "Evidence"
        ],
        "writes": [
          "Evidence",
          "AuditEvent"
        ],
        "service": "AttachEvidence",
        "note": "The bounded auto-write: persist a gathered Evidence artifact against the Control, audited. Called by the workflow's evidence-gather step (auto \u2014 no human sign-off for evidence)."
      },
      {
        "name": "RecordAttestation",
        "actor": "control_owner",
        "reads": [
          "Control",
          "Evidence",
          "GapFinding"
        ],
        "writes": [
          "Attestation",
          "Control",
          "AuditEvent"
        ],
        "service": "RecordAttestation",
        "note": "The HUMAN write to the system of record: a control_owner records an Attestation and marks the Control satisfied, audited. Called by the workflow only AFTER the control_owner approves at the approval step \u2014 never by the agent."
      },
      {
        "name": "ControlReviewWorkflow",
        "orchestrates": true,
        "triggerEvent": "ControlReviewStarted",
        "steps": [
          {
            "name": "GatherEvidence",
            "ai": "ComplianceAgent",
            "reads": [
              "Control",
              "Framework"
            ],
            "writes": [
              "Evidence"
            ]
          },
          {
            "name": "DetectGaps",
            "ai": "ComplianceAgent",
            "reads": [
              "Control",
              "Evidence"
            ],
            "writes": [
              "GapFinding",
              "RemediationTask"
            ]
          },
          {
            "name": "Attest",
            "callsService": "RecordAttestation"
          }
        ],
        "note": "HITL via OutSystems BPT: on ControlReviewStarted the workflow runs the ComplianceAgent to gather+auto-attach Evidence, then to detect gaps and draft remediation. It then HOLDS at a Human Approval activity until the control_owner approves the attestation; ONLY THEN does it call RecordAttestation to mark the Control satisfied. Evidence auto-attaches; the attestation is the human-gated write. The approval + audit is native workflow, not custom code."
      },
      {
        "name": "AttestationInbox",
        "actor": "control_owner",
        "reads": [
          "Control",
          "Evidence",
          "GapFinding",
          "Attestation"
        ],
        "writes": [
          "Attestation",
          "AuditEvent"
        ],
        "service": "ApproveAttestation",
        "note": "The control-owner inbox \u2014 where a human reviews the gathered evidence + gaps for a held control and approves/rejects the attestation. This is the write-step sign-off before RecordAttestation lands."
      },
      {
        "name": "ManageFrameworks",
        "actor": "admin",
        "reads": [
          "Framework",
          "Control"
        ],
        "writes": [
          "Framework",
          "Control"
        ],
        "service": "SaveFramework",
        "note": "Admin maintains the frameworks + controls corpus (SOC2/ISO requirements) the agent grounds on."
      },
      {
        "name": "CompliancePosture",
        "actor": "compliance_analyst",
        "reads": [
          "Control",
          "Framework",
          "GapFinding",
          "RemediationTask",
          "Evidence"
        ]
      },
      {
        "name": "AuditTrail",
        "actor": "admin",
        "reads": [
          "AuditEvent",
          "Control"
        ]
      }
    ],
    "integrations": [
      {
        "name": "EvidenceSources",
        "kind": "consume",
        "purpose": "external evidence sources (cloud config / ticketing / IdP REST) the ComplianceAgent can retrieve control evidence from as a tool",
        "stub": true
      },
      {
        "name": "GrcSystem",
        "kind": "consume",
        "purpose": "external GRC platform sync for controls, attestations, and remediation status",
        "stub": true
      }
    ],
    "libraries": [
      "ComplianceDesignSystem"
    ]
  }
}
