{
  "specVersion": "0.1",
  "system": {
    "name": "field_service",
    "apps": [
      {
        "name": "FieldServiceDesignSystem",
        "kind": "Library",
        "layer": "foundation",
        "exposes": {}
      },
      {
        "name": "FieldserviceCore",
        "kind": "WebApplication",
        "layer": "core",
        "context": "fieldservice",
        "owns": [
          "Asset",
          "Part",
          "Technician",
          "ServiceRequest",
          "Symptom",
          "Diagnosis",
          "WorkOrder",
          "DispatchProposal",
          "AuditEvent"
        ],
        "exposes": {
          "serviceActions": [
            "LogServiceRequest",
            "DiagnoseAndPropose",
            "DispatchTechnician",
            "CommitParts",
            "ApproveDispatch",
            "SaveCatalog"
          ],
          "events": [
            "ServiceRequestLogged"
          ],
          "staticEntities": []
        },
        "foreignKeys": [
          {
            "from": "ServiceRequest",
            "target": "Asset"
          },
          {
            "from": "ServiceRequest",
            "target": "AuditEvent"
          },
          {
            "from": "Symptom",
            "target": "ServiceRequest"
          },
          {
            "from": "Diagnosis",
            "target": "ServiceRequest"
          },
          {
            "from": "Diagnosis",
            "target": "Asset"
          },
          {
            "from": "WorkOrder",
            "target": "ServiceRequest"
          },
          {
            "from": "WorkOrder",
            "target": "Diagnosis"
          },
          {
            "from": "WorkOrder",
            "target": "Technician"
          },
          {
            "from": "DispatchProposal",
            "target": "WorkOrder"
          },
          {
            "from": "DispatchProposal",
            "target": "Diagnosis"
          },
          {
            "from": "DispatchProposal",
            "target": "Technician"
          }
        ],
        "consumes": []
      },
      {
        "name": "DispatchAgent",
        "kind": "AIAgent",
        "layer": "orchestration",
        "exposes": {
          "serviceActions": [
            "DispatchAgent"
          ]
        },
        "consumes": [
          {
            "app": "FieldserviceCore",
            "entities": [
              "Part",
              "Symptom",
              "ServiceRequest",
              "Asset"
            ]
          }
        ]
      },
      {
        "name": "DispatchWorkflow",
        "kind": "BusinessProcess",
        "layer": "orchestration",
        "process": {
          "triggerEvent": "ServiceRequestLogged",
          "startProcessOn": "FieldserviceCore.ServiceRequestLogged"
        },
        "activities": [
          {
            "name": "Diagnose",
            "callsServiceAction": "DispatchAgent"
          },
          {
            "name": "PartsLookup",
            "callsServiceAction": "DispatchAgent"
          },
          {
            "name": "ApproveDispatch",
            "callsServiceAction": "DispatchTechnician"
          },
          {
            "name": "CommitInventory",
            "callsServiceAction": "CommitParts"
          }
        ],
        "consumes": [
          {
            "app": "FieldserviceCore",
            "events": [
              "ServiceRequestLogged"
            ],
            "serviceActions": [
              "CommitParts",
              "DispatchTechnician"
            ]
          },
          {
            "app": "DispatchAgent",
            "serviceActions": [
              "DispatchAgent"
            ]
          }
        ]
      },
      {
        "name": "AdminApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "admin",
        "exposes": {
          "screens": [
            "WorkOrderDashboard",
            "ManageCatalog",
            "AuditTrail"
          ]
        },
        "consumes": [
          {
            "app": "FieldserviceCore",
            "entities": [
              "Asset",
              "AuditEvent",
              "Diagnosis",
              "Part",
              "ServiceRequest",
              "Technician",
              "WorkOrder"
            ],
            "serviceActions": [
              "SaveCatalog"
            ]
          },
          {
            "app": "FieldServiceDesignSystem"
          }
        ]
      },
      {
        "name": "CustomerApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "customer",
        "exposes": {
          "screens": [
            "LogServiceRequest"
          ]
        },
        "consumes": [
          {
            "app": "FieldserviceCore",
            "entities": [
              "Asset",
              "AuditEvent",
              "ServiceRequest",
              "Symptom"
            ],
            "serviceActions": [
              "LogServiceRequest"
            ]
          },
          {
            "app": "FieldServiceDesignSystem"
          }
        ]
      },
      {
        "name": "DispatcherApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "dispatcher",
        "exposes": {
          "screens": [
            "DispatchTechnician",
            "CommitParts",
            "DispatcherInbox"
          ]
        },
        "consumes": [
          {
            "app": "FieldserviceCore",
            "entities": [
              "AuditEvent",
              "Diagnosis",
              "DispatchProposal",
              "Part",
              "ServiceRequest",
              "Technician",
              "WorkOrder"
            ],
            "serviceActions": [
              "ApproveDispatch",
              "CommitParts",
              "DispatchTechnician"
            ]
          },
          {
            "app": "FieldServiceDesignSystem"
          }
        ]
      },
      {
        "name": "TechnicianApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "technician",
        "exposes": {
          "screens": [
            "TechWorkboard"
          ]
        },
        "consumes": [
          {
            "app": "FieldserviceCore",
            "entities": [
              "Asset",
              "Diagnosis",
              "ServiceRequest",
              "WorkOrder"
            ]
          },
          {
            "app": "FieldServiceDesignSystem"
          }
        ]
      }
    ]
  }
}