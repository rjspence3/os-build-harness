{
  "specVersion": "0.1",
  "system": {
    "name": "knowledge_assistant",
    "apps": [
      {
        "name": "KnowledgeDesignSystem",
        "kind": "Library",
        "layer": "foundation",
        "exposes": {}
      },
      {
        "name": "KnowledgeCore",
        "kind": "WebApplication",
        "layer": "core",
        "context": "knowledge",
        "owns": [
          "KnowledgeDoc",
          "AuditEvent",
          "Question",
          "Answer",
          "Citation",
          "Escalation"
        ],
        "exposes": {
          "serviceActions": [
            "AskQuestion",
            "AnswerQuestion",
            "RecordAnswer",
            "RaiseEscalation",
            "ResolveEscalation",
            "SaveKnowledgeDoc"
          ],
          "events": [
            "QuestionAsked"
          ],
          "staticEntities": []
        },
        "foreignKeys": [
          {
            "from": "Question",
            "target": "AuditEvent"
          },
          {
            "from": "Answer",
            "target": "Question"
          },
          {
            "from": "Citation",
            "target": "Answer"
          },
          {
            "from": "Citation",
            "target": "KnowledgeDoc"
          },
          {
            "from": "Escalation",
            "target": "Question"
          }
        ],
        "consumes": []
      },
      {
        "name": "AnswerWorkflow",
        "kind": "BusinessProcess",
        "layer": "orchestration",
        "process": {
          "triggerEvent": "QuestionAsked",
          "startProcessOn": "KnowledgeCore.QuestionAsked"
        },
        "activities": [
          {
            "name": "Answer",
            "callsServiceAction": "KnowledgeAssistAgent"
          },
          {
            "name": "RecordOrEscalate",
            "callsServiceAction": "RecordAnswer"
          }
        ],
        "consumes": [
          {
            "app": "KnowledgeCore",
            "events": [
              "QuestionAsked"
            ],
            "serviceActions": [
              "RecordAnswer"
            ]
          },
          {
            "app": "KnowledgeAssistAgent",
            "serviceActions": [
              "KnowledgeAssistAgent"
            ]
          }
        ]
      },
      {
        "name": "KnowledgeAssistAgent",
        "kind": "AIAgent",
        "layer": "orchestration",
        "exposes": {
          "serviceActions": [
            "KnowledgeAssistAgent"
          ]
        },
        "consumes": [
          {
            "app": "KnowledgeCore",
            "entities": [
              "KnowledgeDoc",
              "Question"
            ]
          }
        ]
      },
      {
        "name": "AdminApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "admin",
        "exposes": {
          "screens": [
            "ManageCorpus",
            "AuditTrail"
          ]
        },
        "consumes": [
          {
            "app": "KnowledgeCore",
            "entities": [
              "AuditEvent",
              "KnowledgeDoc",
              "Question"
            ],
            "serviceActions": [
              "SaveKnowledgeDoc"
            ]
          },
          {
            "app": "KnowledgeDesignSystem"
          }
        ]
      },
      {
        "name": "EmployeeApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "employee",
        "exposes": {
          "screens": [
            "AskQuestion",
            "QAHistory"
          ]
        },
        "consumes": [
          {
            "app": "KnowledgeCore",
            "entities": [
              "Answer",
              "AuditEvent",
              "Citation",
              "KnowledgeDoc",
              "Question"
            ],
            "serviceActions": [
              "AskQuestion"
            ]
          },
          {
            "app": "KnowledgeDesignSystem"
          }
        ]
      },
      {
        "name": "SubjectExpertApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "subject_expert",
        "exposes": {
          "screens": [
            "RecordAnswer",
            "RaiseEscalation",
            "ExpertInbox"
          ]
        },
        "consumes": [
          {
            "app": "KnowledgeCore",
            "entities": [
              "Answer",
              "AuditEvent",
              "Citation",
              "Escalation",
              "Question"
            ],
            "serviceActions": [
              "RaiseEscalation",
              "RecordAnswer",
              "ResolveEscalation"
            ]
          },
          {
            "app": "KnowledgeDesignSystem"
          }
        ]
      }
    ]
  }
}