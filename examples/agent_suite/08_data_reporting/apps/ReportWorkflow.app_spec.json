        {
          "name": "PublishReport",
          "kind": "ServiceAction"
        }
      ]
    },
    {
      "producerApp": "AnalyticsAgent",
      "elements": [
        {
          "name": "AnalyticsAgent",
          "kind": "ServiceAction"
        }
      ]
    }
  ]
