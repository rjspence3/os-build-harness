{
  "specVersion": "0.1",
  "system": {
    "name": "data_reporting",
    "apps": [
      {
        "name": "AnalyticsDesignSystem",
        "kind": "Library",
        "layer": "foundation",
        "exposes": {}
      },
      {
        "name": "AnalyticsCore",
        "kind": "WebApplication",
        "layer": "core",
        "context": "analytics",
        "owns": [
          "DataSource",
          "ReportDefinition",
          "QueryRequest",
          "ReportRun",
          "AnomalyFinding",
          "Distribution",
          "AuditEvent"
        ],
        "exposes": {
          "serviceActions": [
            "RequestReport",
            "AnalyzeData",
            "PublishReport",
            "DistributeReport",
            "ApproveDistribution",
            "SaveDataSource"
          ],
          "events": [
            "ReportRequested"
          ],
          "staticEntities": []
        },
        "foreignKeys": [
          {
            "from": "ReportDefinition",
            "target": "DataSource"
          },
          {
            "from": "QueryRequest",
            "target": "DataSource"
          },
          {
            "from": "ReportRun",
            "target": "ReportDefinition"
          },
          {
            "from": "AnomalyFinding",
            "target": "ReportRun"
          },
          {
            "from": "Distribution",
            "target": "ReportRun"
          },
          {
            "from": "AuditEvent",
            "target": "ReportRun"
          }
        ],
        "consumes": []
      },
      {
        "name": "AnalyticsAgent",
        "kind": "AIAgent",
        "layer": "orchestration",
        "exposes": {
          "serviceActions": [
            "AnalyticsAgent"
          ]
        },
        "consumes": [
          {
            "app": "AnalyticsCore",
            "entities": [
              "ReportDefinition",
              "DataSource"
            ]
          }
        ]
      },
      {
        "name": "ReportWorkflow",
        "kind": "BusinessProcess",
        "layer": "orchestration",
        "process": {
          "triggerEvent": "ReportRequested",
          "startProcessOn": "AnalyticsCore.ReportRequested"
        },
        "activities": [
          {
            "name": "Analyze",
            "callsServiceAction": "AnalyticsAgent"
          },
          {
            "name": "Generate",
            "callsServiceAction": "PublishReport"
          },
          {
            "name": "Approve",
            "callsServiceAction": "DistributeReport"
          }
        ],
        "consumes": [
          {
            "app": "AnalyticsCore",
            "events": [
              "ReportRequested"
            ],
            "serviceActions": [
              "DistributeReport",
              "PublishReport"
            ]
          },
          {
            "app": "AnalyticsAgent",
            "serviceActions": [
              "AnalyticsAgent"
            ]
          }
        ]
      },
      {
        "name": "AdminApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "admin",
        "exposes": {
          "screens": [
            "ManageDataSources",
            "AuditTrail"
          ]
        },
        "consumes": [
          {
            "app": "AnalyticsCore",
            "entities": [
              "AuditEvent",
              "DataSource",
              "ReportDefinition",
              "ReportRun"
            ],
            "serviceActions": [
              "SaveDataSource"
            ]
          },
          {
            "app": "AnalyticsDesignSystem"
          }
        ]
      },
      {
        "name": "AnalystApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "analyst",
        "exposes": {
          "screens": [
            "RequestReport",
            "MyReports",
            "AnomalyDashboard"
          ]
        },
        "consumes": [
          {
            "app": "AnalyticsCore",
            "entities": [
              "AnomalyFinding",
              "AuditEvent",
              "DataSource",
              "QueryRequest",
              "ReportDefinition",
              "ReportRun"
            ],
            "serviceActions": [
              "RequestReport"
            ]
          },
          {
            "app": "AnalyticsDesignSystem"
          }
        ]
      },
      {
        "name": "DataLeadApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "data_lead",
        "exposes": {
          "screens": [
            "PublishReport",
            "DistributeReport",
            "ApprovalInbox"
          ]
        },
        "consumes": [
          {
            "app": "AnalyticsCore",
            "entities": [
              "AnomalyFinding",
              "AuditEvent",
              "Distribution",
              "ReportDefinition",
              "ReportRun"
            ],
            "serviceActions": [
              "ApproveDistribution",
              "DistributeReport",
              "PublishReport"
            ]
          },
          {
            "app": "AnalyticsDesignSystem"
          }
        ]
      }
    ]
  }
}