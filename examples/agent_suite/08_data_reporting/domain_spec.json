{
  "specVersion": "0.1",
  "domain": {
    "name": "data_reporting",
    "description": "Data analysis & reporting (use case #8). An AnalyticsAgent answers natural-language questions over a warehouse, generates recurring reports, and narrates anomalies. It grounds on the DataSource schema + the governing ReportDefinition and PROPOSES a bounded action (run-query | generate-report | narrate-anomaly) \u2014 it writes a QueryRequest, a ReportRun, or an AnomalyFinding, but it NEVER distributes to stakeholders directly. Ad-hoc queries and report drafts are auto; anything that gets PUBLISHED/DISTRIBUTED to stakeholders holds at an OutSystems Human Approval activity (BPT) until a data_lead signs off before the write lands. The bounded action space (run-query | generate-report | narrate-anomaly) + the human-at-the-distribute-step is what makes it ship, not just reason. Every action is audited.",
    "entities": [
      {
        "name": "DataSource",
        "context": "analytics",
        "naturalKey": "Code",
        "attributes": [
          {
            "name": "Code",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Name",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Kind",
            "dataType": "Text"
          },
          {
            "name": "ConnectionUri",
            "dataType": "Text"
          },
          {
            "name": "SchemaDoc",
            "dataType": "Text"
          },
          {
            "name": "Active",
            "dataType": "Boolean"
          }
        ]
      },
      {
        "name": "ReportDefinition",
        "context": "analytics",
        "naturalKey": "Code",
        "references": [
          "DataSource"
        ],
        "attributes": [
          {
            "name": "Code",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Title",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Description",
            "dataType": "Text",
            "length": 2000
          },
          {
            "name": "Schedule",
            "dataType": "Text"
          },
          {
            "name": "Audience",
            "dataType": "Text"
          },
          {
            "name": "Active",
            "dataType": "Boolean"
          }
        ]
      },
      {
        "name": "QueryRequest",
        "context": "analytics",
        "naturalKey": "RequestNo",
        "references": [
          "DataSource"
        ],
        "attributes": [
          {
            "name": "RequestNo",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Question",
            "dataType": "Text",
            "mandatory": true,
            "length": 2000
          },
          {
            "name": "GeneratedSql",
            "dataType": "Text"
          },
          {
            "name": "ResultSummary",
            "dataType": "Text"
          },
          {
            "name": "RowCount",
            "dataType": "Integer"
          },
          {
            "name": "Status",
            "dataType": "Text"
          },
          {
            "name": "ConfidenceScore",
            "dataType": "Integer"
          }
        ]
      },
      {
        "name": "ReportRun",
        "context": "analytics",
        "naturalKey": "RunNo",
        "references": [
          "ReportDefinition"
        ],
        "attributes": [
          {
            "name": "RunNo",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "ActionType",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Narrative",
            "dataType": "Text",
            "length": 2000
          },
          {
            "name": "ArtifactUri",
            "dataType": "Text"
          },
          {
            "name": "GeneratedAt",
            "dataType": "DateTime"
          },
          {
            "name": "RiskTier",
            "dataType": "Text"
          },
          {
            "name": "Status",
            "dataType": "Text"
          },
          {
            "name": "ApprovedBy",
            "dataType": "Text"
          }
        ]
      },
      {
        "name": "AnomalyFinding",
        "context": "analytics",
        "references": [
          "ReportRun"
        ],
        "attributes": [
          {
            "name": "Metric",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "ObservedValue",
            "dataType": "Decimal"
          },
          {
            "name": "ExpectedValue",
            "dataType": "Decimal"
          },
          {
            "name": "Deviation",
            "dataType": "Decimal"
          },
          {
            "name": "Narrative",
            "dataType": "Text",
            "length": 2000
          },
          {
            "name": "Severity",
            "dataType": "Text"
          },
          {
            "name": "Status",
            "dataType": "Text"
          }
        ]
      },
      {
        "name": "Distribution",
        "context": "analytics",
        "references": [
          "ReportRun"
        ],
        "attributes": [
          {
            "name": "Channel",
            "dataType": "Text",
            "mandatory": true
          },
          {
            "name": "Recipients",
            "dataType": "Text"
          },
          {
            "name": "SentAt",
            "dataType": "DateTime"
          },
          {
            "name": "Status",
            "dataType": "Text"
          },
          {
            "name": "ApprovedBy",
            "dataType": "Text"
          }
        ]
      },
      {
        "name": "AuditEvent",
        "context": "analytics",
        "references": [
          "ReportRun"
        ],
        "attributes": [
          {
            "name": "Description",
            "dataType": "Text",
            "mandatory": true,
            "length": 2000
          },
          {
            "name": "Actor",
            "dataType": "Text"
          },
          {
            "name": "At",
            "dataType": "DateTime"
          }
        ]
      }
    ],
    "actors": [
      "analyst",
      "data_lead",
      "admin"
    ],
    "capabilities": [
      {
        "name": "RequestReport",
        "actor": "analyst",
        "reads": [
          "ReportDefinition",
          "DataSource"
        ],
        "writes": [
          "ReportRun",
          "AuditEvent"
        ],
        "service": "RequestReport",
        "raisesEvent": "ReportRequested",
        "note": "Analyst intake \u2014 requests a report run (or an ad-hoc analysis) against a ReportDefinition and kicks off the analysis flow."
      },
      {
        "name": "AnalyzeData",
        "ai": "AnalyticsAgent",
        "reads": [
          "DataSource",
          "ReportDefinition",
          "QueryRequest",
          "ReportRun"
        ],
        "writes": [
          "QueryRequest",
          "ReportRun",
          "AnomalyFinding",
          "AuditEvent"
        ],
        "service": "AnalyzeData",
        "note": "THE AGENT. Grounds on the DataSource SchemaDoc + the governing ReportDefinition (native retrieval tool), answers a natural-language question, generates the recurring report, and narrates anomalies \u2014 PROPOSING one bounded action (run-query | generate-report | narrate-anomaly): it writes a QueryRequest, a ReportRun, or an AnomalyFinding each with a RiskTier. It never distributes to stakeholders directly \u2014 it proposes."
      },
      {
        "name": "PublishReport",
        "actor": "data_lead",
        "reads": [
          "ReportRun",
          "AnomalyFinding"
        ],
        "writes": [
          "ReportRun",
          "AuditEvent"
        ],
        "service": "PublishReport",
        "note": "The bounded WRITE to the system of record: mark the ReportRun published (available in the catalog), audited. Called by the workflow after approval (or auto for ad-hoc drafts)."
      },
      {
        "name": "DistributeReport",
        "actor": "data_lead",
        "reads": [
          "ReportRun",
          "ReportDefinition"
        ],
        "writes": [
          "Distribution",
          "AuditEvent"
        ],
        "service": "DistributeReport",
        "note": "The other bounded write \u2014 the human-gated one: distribute the published ReportRun to stakeholders (create a Distribution row + send), audited. Only reached after a data_lead approves."
      },
      {
        "name": "ReportWorkflow",
        "orchestrates": true,
        "triggerEvent": "ReportRequested",
        "steps": [
          {
            "name": "Analyze",
            "ai": "AnalyticsAgent",
            "reads": [
              "DataSource",
              "ReportDefinition"
            ],
            "writes": [
              "ReportRun"
            ]
          },
          {
            "name": "Generate",
            "callsService": "PublishReport"
          },
          {
            "name": "Approve",
            "callsService": "DistributeReport"
          }
        ],
        "note": "HITL via OutSystems BPT: on ReportRequested the workflow runs the AnalyticsAgent to run the query + generate the ReportRun (and narrate anomalies); low RiskTier (ad-hoc query / draft) auto-calls PublishReport, but any run destined for stakeholders holds at a Human Approval activity until a data_lead approves, THEN calls DistributeReport. The approval + audit is native workflow, not custom code."
      },
      {
        "name": "MyReports",
        "actor": "analyst",
        "reads": [
          "ReportRun",
          "ReportDefinition",
          "QueryRequest",
          "AnomalyFinding"
        ]
      },
      {
        "name": "ApprovalInbox",
        "actor": "data_lead",
        "reads": [
          "ReportRun",
          "AnomalyFinding",
          "ReportDefinition"
        ],
        "writes": [
          "ReportRun",
          "AuditEvent"
        ],
        "service": "ApproveDistribution",
        "note": "Where a data_lead approves/rejects a held report-run before it is distributed to stakeholders \u2014 the write-step sign-off."
      },
      {
        "name": "ManageDataSources",
        "actor": "admin",
        "reads": [
          "DataSource",
          "ReportDefinition"
        ],
        "writes": [
          "DataSource",
          "ReportDefinition"
        ],
        "service": "SaveDataSource",
        "note": "Admin maintains the data sources + report definitions (schemas, schedules, audiences) the agent grounds on."
      },
      {
        "name": "AnomalyDashboard",
        "actor": "analyst",
        "reads": [
          "AnomalyFinding",
          "ReportRun",
          "ReportDefinition"
        ]
      },
      {
        "name": "AuditTrail",
        "actor": "admin",
        "reads": [
          "AuditEvent",
          "ReportRun"
        ]
      }
    ],
    "integrations": [
      {
        "name": "Warehouse",
        "kind": "consume",
        "purpose": "the data warehouse / BI system (Snowflake/BigQuery-style REST) the AnalyticsAgent runs queries against and retrieves schema + result sets from",
        "stub": true
      },
      {
        "name": "Notify",
        "kind": "consume",
        "purpose": "notification/distribution channel (email/Slack-style REST) DistributeReport sends the published report to stakeholders through",
        "stub": true
      }
    ],
    "libraries": [
      "AnalyticsDesignSystem"
    ]
  }
}
