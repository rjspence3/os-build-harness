{
  "specVersion": "0.1",
  "system": {
    "name": "coding_testgen",
    "apps": [
      {
        "name": "DevToolsDesignSystem",
        "kind": "Library",
        "layer": "foundation",
        "exposes": {}
      },
      {
        "name": "DevtasksCore",
        "kind": "WebApplication",
        "layer": "core",
        "context": "devtasks",
        "owns": [
          "Repository",
          "WorkItem",
          "ChangeProposal",
          "TestSuite",
          "PullRequest",
          "ReviewComment",
          "AuditEvent"
        ],
        "exposes": {
          "serviceActions": [
            "AssignWorkItem",
            "DraftChange",
            "OpenPullRequest",
            "RecordReview",
            "ApprovePullRequest",
            "SaveRepository"
          ],
          "events": [
            "WorkItemAssigned"
          ],
          "staticEntities": []
        },
        "foreignKeys": [
          {
            "from": "WorkItem",
            "target": "Repository"
          },
          {
            "from": "WorkItem",
            "target": "AuditEvent"
          },
          {
            "from": "ChangeProposal",
            "target": "WorkItem"
          },
          {
            "from": "ChangeProposal",
            "target": "Repository"
          },
          {
            "from": "TestSuite",
            "target": "ChangeProposal"
          },
          {
            "from": "TestSuite",
            "target": "WorkItem"
          },
          {
            "from": "PullRequest",
            "target": "ChangeProposal"
          },
          {
            "from": "PullRequest",
            "target": "Repository"
          },
          {
            "from": "PullRequest",
            "target": "WorkItem"
          },
          {
            "from": "ReviewComment",
            "target": "PullRequest"
          }
        ],
        "consumes": []
      },
      {
        "name": "CodeGenAgent",
        "kind": "AIAgent",
        "layer": "orchestration",
        "exposes": {
          "serviceActions": [
            "CodeGenAgent"
          ]
        },
        "consumes": [
          {
            "app": "DevtasksCore",
            "entities": [
              "WorkItem",
              "Repository"
            ]
          }
        ]
      },
      {
        "name": "TestGenWorkflow",
        "kind": "BusinessProcess",
        "layer": "orchestration",
        "process": {
          "triggerEvent": "WorkItemAssigned",
          "startProcessOn": "DevtasksCore.WorkItemAssigned"
        },
        "activities": [
          {
            "name": "Draft",
            "callsServiceAction": "CodeGenAgent"
          },
          {
            "name": "GenerateTests",
            "callsServiceAction": "CodeGenAgent"
          },
          {
            "name": "Review",
            "callsServiceAction": "OpenPullRequest"
          }
        ],
        "consumes": [
          {
            "app": "DevtasksCore",
            "events": [
              "WorkItemAssigned"
            ],
            "serviceActions": [
              "OpenPullRequest"
            ]
          },
          {
            "app": "CodeGenAgent",
            "serviceActions": [
              "CodeGenAgent"
            ]
          }
        ]
      },
      {
        "name": "AdminApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "admin",
        "exposes": {
          "screens": [
            "ManageRepositories",
            "BuildDashboard"
          ]
        },
        "consumes": [
          {
            "app": "DevtasksCore",
            "entities": [
              "AuditEvent",
              "PullRequest",
              "Repository",
              "WorkItem"
            ],
            "serviceActions": [
              "SaveRepository"
            ]
          },
          {
            "app": "DevToolsDesignSystem"
          }
        ]
      },
      {
        "name": "DeveloperApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "developer",
        "exposes": {
          "screens": [
            "AssignWorkItem",
            "OpenPullRequest",
            "MyWork"
          ]
        },
        "consumes": [
          {
            "app": "DevtasksCore",
            "entities": [
              "AuditEvent",
              "ChangeProposal",
              "PullRequest",
              "Repository",
              "TestSuite",
              "WorkItem"
            ],
            "serviceActions": [
              "AssignWorkItem",
              "OpenPullRequest"
            ]
          },
          {
            "app": "DevToolsDesignSystem"
          }
        ]
      },
      {
        "name": "ReviewerApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "reviewer",
        "exposes": {
          "screens": [
            "RecordReview",
            "ReviewInbox"
          ]
        },
        "consumes": [
          {
            "app": "DevtasksCore",
            "entities": [
              "AuditEvent",
              "ChangeProposal",
              "PullRequest",
              "ReviewComment",
              "TestSuite"
            ],
            "serviceActions": [
              "ApprovePullRequest",
              "RecordReview"
            ]
          },
          {
            "app": "DevToolsDesignSystem"
          }
        ]
      }
    ]
  }
}