{
  "specVersion": "0.2",
  "app": {
    "name": "PostingWorkflow",
    "roles": [
      "User"
    ],
    "description": "Business process (BPT orchestration)"
  },
  "dataModel": {
    "entities": []
  },
  "screens": [],
