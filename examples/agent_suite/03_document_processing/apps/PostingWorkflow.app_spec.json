        }
      ]
    }
  ],
  "appReferences": [
    {
      "producerApp": "DocprocCore",
      "elements": [
        {
          "name": "PostToLedger",
          "kind": "ServiceAction"
        },
        {
          "name": "RouteForReview",
          "kind": "ServiceAction"
        }
      ]
    },
    {
      "producerApp": "DocExtractAgent",
      "elements": [
        {
          "name": "DocExtractAgent",
          "kind": "ServiceAction"
        }
      ]
    }
  ]
}