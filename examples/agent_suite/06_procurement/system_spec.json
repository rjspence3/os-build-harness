{
  "specVersion": "0.1",
  "system": {
    "name": "procurement",
    "apps": [
      {
        "name": "ProcurementDesignSystem",
        "kind": "Library",
        "layer": "foundation",
        "exposes": {}
      },
      {
        "name": "ProcurementCore",
        "kind": "WebApplication",
        "layer": "core",
        "context": "procurement",
        "owns": [
          "Vendor",
          "PurchaseOrder",
          "GoodsReceipt",
          "Invoice",
          "MatchResult",
          "PaymentProposal",
          "AuditEvent"
        ],
        "exposes": {
          "serviceActions": [
            "ReceiveInvoice",
            "MatchInvoice",
            "ReleasePayment",
            "FlagException",
            "ApprovePayment",
            "SaveVendor"
          ],
          "events": [
            "InvoiceReceived"
          ],
          "staticEntities": []
        },
        "foreignKeys": [
          {
            "from": "PurchaseOrder",
            "target": "Vendor"
          },
          {
            "from": "PurchaseOrder",
            "target": "AuditEvent"
          },
          {
            "from": "GoodsReceipt",
            "target": "PurchaseOrder"
          },
          {
            "from": "Invoice",
            "target": "PurchaseOrder"
          },
          {
            "from": "Invoice",
            "target": "Vendor"
          },
          {
            "from": "MatchResult",
            "target": "Invoice"
          },
          {
            "from": "MatchResult",
            "target": "PurchaseOrder"
          },
          {
            "from": "MatchResult",
            "target": "GoodsReceipt"
          },
          {
            "from": "PaymentProposal",
            "target": "Invoice"
          },
          {
            "from": "PaymentProposal",
            "target": "MatchResult"
          },
          {
            "from": "PaymentProposal",
            "target": "Vendor"
          }
        ],
        "consumes": []
      },
      {
        "name": "MatchWorkflow",
        "kind": "BusinessProcess",
        "layer": "orchestration",
        "process": {
          "triggerEvent": "InvoiceReceived",
          "startProcessOn": "ProcurementCore.InvoiceReceived"
        },
        "activities": [
          {
            "name": "Match",
            "callsServiceAction": "PoMatchAgent"
          },
          {
            "name": "Approve",
            "callsServiceAction": "ReleasePayment"
          }
        ],
        "consumes": [
          {
            "app": "ProcurementCore",
            "events": [
              "InvoiceReceived"
            ],
            "serviceActions": [
              "ReleasePayment"
            ]
          },
          {
            "app": "PoMatchAgent",
            "serviceActions": [
              "PoMatchAgent"
            ]
          }
        ]
      },
      {
        "name": "PoMatchAgent",
        "kind": "AIAgent",
        "layer": "orchestration",
        "exposes": {
          "serviceActions": [
            "PoMatchAgent"
          ]
        },
        "consumes": [
          {
            "app": "ProcurementCore",
            "entities": [
              "GoodsReceipt",
              "Invoice",
              "PurchaseOrder"
            ]
          }
        ]
      },
      {
        "name": "AdminApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "admin",
        "exposes": {
          "screens": [
            "ManageVendors"
          ]
        },
        "consumes": [
          {
            "app": "ProcurementCore",
            "entities": [
              "Vendor"
            ],
            "serviceActions": [
              "SaveVendor"
            ]
          },
          {
            "app": "ProcurementDesignSystem"
          }
        ]
      },
      {
        "name": "ApClerkApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "ap_clerk",
        "exposes": {
          "screens": [
            "ReceiveInvoice",
            "ReleasePayment",
            "FlagException",
            "MyQueue"
          ]
        },
        "consumes": [
          {
            "app": "ProcurementCore",
            "entities": [
              "AuditEvent",
              "GoodsReceipt",
              "Invoice",
              "MatchResult",
              "PaymentProposal",
              "PurchaseOrder",
              "Vendor"
            ],
            "serviceActions": [
              "FlagException",
              "ReceiveInvoice",
              "ReleasePayment"
            ]
          },
          {
            "app": "ProcurementDesignSystem"
          }
        ]
      },
      {
        "name": "ProcurementManagerApp",
        "kind": "WebApplication",
        "layer": "enduser",
        "actor": "procurement_manager",
        "exposes": {
          "screens": [
            "ApprovalInbox",
            "SpendDashboard"
          ]
        },
        "consumes": [
          {
            "app": "ProcurementCore",
            "entities": [
              "AuditEvent",
              "Invoice",
              "MatchResult",
              "PaymentProposal",
              "PurchaseOrder"
            ],
            "serviceActions": [
              "ApprovePayment"
            ]
          },
          {
            "app": "ProcurementDesignSystem"
          }
        ]
      }
    ]
  }
}